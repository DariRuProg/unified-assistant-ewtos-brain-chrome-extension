# EwtosBrain — Server-Secrets
# Kopiere diese Datei nach .env und trage deine echten Keys ein.
# .env wird NICHT versioniert (steht in .gitignore).

# Anthropic (Default-Provider)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (optional — nur nötig wenn Provider auf "openai" gestellt)
OPENAI_API_KEY=sk-...

# Mistral (optional — nur nötig wenn Provider auf "mistral" gestellt)
MISTRAL_API_KEY=...

# OpenRouter (optional — nur nötig wenn Provider auf "openrouter" gestellt).
# Ein Key, beliebige Modelle (Slug provider/model). Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Ollama braucht keinen API-Key — Base-URL in der Settings-UI konfigurieren
# (Default: http://localhost:11434)

# External Services -------------------------------------------------------
# Google Gemini — Image Generation (Nano Banana). Wird vom Image-Gen-Tool
# benoetigt und kuenftig auch vom Briefing-Tool. Key bekommst du in
# https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# YouTube Data API v3 fuer Briefing-Quellen (youtube_trending, competitor_videos)
YOUTUBE_API_KEY=

# ElevenLabs (optional) — Text-to-Speech fuer das Vorlesen von Chat-Antworten (BYOK).
# Key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
