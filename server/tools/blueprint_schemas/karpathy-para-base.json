{
  "schema_version": "1.0",
  "blueprint_id": "karpathy-para-base",
  "blueprint_name": "Karpathy-Farming (Wissens-Pipeline)",
  "blueprint_version": "2.0.0",
  "author": "ewtos.com",
  "license": "MIT",
  "description": "Self-Feeding Wiki nach Karpathy/Bonanno: erbt das Kontext-Profil und ergänzt die Farming-Pipeline (raw/ → wiki/resources mit Creators/Videos/Playlists). Für alle, die Wissen aus Quellen (YouTube, Artikel) systematisch ins Wiki überführen.",
  "tags": ["karpathy", "para", "farming", "video"],
  "category": "addon",
  "when_to_use": "Wenn du Wissen aus Quellen (YouTube, Artikel) systematisch ins Wiki überführst — Video/Creator/Playlist-Vorlagen, raw/-Ordner und die Commands /ingest /query /farm.",
  "extends": ["kontext-base"],
  "folders": [
    { "path": "raw/youtube", "kind": "raw" },
    { "path": "raw/artikel", "kind": "raw" },
    { "path": "raw/eigene-notizen", "kind": "raw" },
    { "path": "raw/kunden-input", "kind": "raw" },
    { "path": "raw/chat-archive", "kind": "raw" },
    { "path": "raw/assets", "kind": "raw" },
    { "path": "wiki/resources/creators", "kind": "asset", "asset_type": "creator", "emoji": "🎙" },
    { "path": "wiki/resources/videos", "kind": "asset", "asset_type": "video", "emoji": "🎬" },
    { "path": "wiki/resources/playlists", "kind": "asset", "asset_type": "playlist", "emoji": "🎵" }
  ],
  "files": [
    { "path": "agents.md", "template": "karpathy-para-base/agents.md.j2", "merge_policy": "skip_if_exists" },
    { "path": "templates/video.md", "template": "karpathy-para-base/templates/video.md.j2", "merge_policy": "skip_if_exists" },
    { "path": "templates/creator.md", "template": "karpathy-para-base/templates/creator.md.j2", "merge_policy": "skip_if_exists" },
    { "path": "templates/playlist.md", "template": "karpathy-para-base/templates/playlist.md.j2", "merge_policy": "skip_if_exists" }
  ],
  "bases": [],
  "claude_md_sections": [
    {
      "id": "vault-schema",
      "order": 10,
      "title": "Vault-Schema",
      "template": "karpathy-para-base/claude-md/intro.md.j2",
      "merge_policy": "replace_if_marker"
    },
    {
      "id": "karpathy-routinen",
      "order": 20,
      "title": "Routinen (Karpathy)",
      "template": "karpathy-para-base/claude-md/routinen.md.j2",
      "merge_policy": "replace_if_marker"
    }
  ],
  "briefing_sources": ["lernstreak"],
  "permissions_defaults": {},
  "commands": ["ingest", "query", "farm"]
}
